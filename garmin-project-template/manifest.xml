<?xml version="1.0"?>
<!-- Reference template — actual manifest is generated by server.js into exported-garmin-project/ -->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <!-- minSdkVersion must match garmin-project-template/VERSION minApiLevel.
         Update both files together. See CLAUDE.md §Template versioning contract. -->
    <!-- entry must match: lib/generators/manifest.js entry value AND
         the App class name in the generated Monkey C source (WatchFaceApp extends App.AppBase).
         The view class is WatchFaceView — these are different. Do not confuse them.
         Update lib/generators/manifest.js and generated .mc together if this ever changes. -->
    <iq:application
        entry="WatchFaceApp"
        id="a3872ef0-6346-4321-abcd-000000000000"
        minSdkVersion="4.2.0"
        name="@Strings.AppName"
        type="watchFace"
        version="1.0.0">
        <iq:products>
            <!-- vivoactive6: native device definition confirmed in SDK 9.1.0 -->
            <iq:product id="vivoactive6"/>
        </iq:products>
        <iq:permissions>
            <!-- Permissions are generated dynamically based on placed elements.
                 Use <iq:uses-permission id="..."/> — NOT <iq:permission> (removed in SDK 4+):
                 Sensor        → heartRate, heartRateZone
                 UserProfile   → steps, stepGoal, calories, distance, floorsClimbed, activeMinutes
                 Location      → sunriseSunset, weather
                 SensorHistory → hrGraph, bodyBattery, stress, HRV, SpO2                          -->
        </iq:permissions>
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
