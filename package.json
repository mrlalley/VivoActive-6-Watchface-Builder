{
  "name": "watchface-builder",
  "version": "1.0.0",
  "productName": "WatchFace Builder",
  "description": "Garmin Vivoactive 6 Watch Face Visual Builder",
  "author": "WatchFace Builder",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "server": "node server.js",
    "build": "electron-builder --win --publish never",
    "dist": "npm run build",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "build": {
    "appId": "com.watchfacebuilder.app",
    "productName": "WatchFace Builder",
    "directories": {
      "output": "dist-final"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "builder/**/*",
      "lib/**/*",
      "garmin-project-template/**/*",
      "assets/**/*",
      "server.js",
      "package.json",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "electron-store": "9.0.0",
    "express": "~4.22.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "~7.11.2",
    "@electron-forge/maker-squirrel": "~7.11.2",
    "@electron-forge/maker-zip": "~7.11.2",
    "@jest/globals": "~29.7.0",
    "electron": "42.3.0",
    "electron-builder": "~26.8.1",
    "electron-packager": "~17.1.2",
    "jest": "~29.7.0"
  },
  "allowScripts": {
    "electron@34.5.8": true,
    "electron-winstaller@5.4.0": true
  }
}
