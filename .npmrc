# Enforce exact versions on npm install --save to prevent loose dependencies
save-exact=true

# Use package-lock.json for reproducible installs
package-lock=true

# Audit on install (but don't block on vulnerabilities)
audit=true

# Enforce the engines field in package.json as a hard error (not a warning).
# Prevents silent installs on incompatible Node.js versions.
# Applies only to this project's top-level install — does not affect transitive deps.
engine-strict=true
