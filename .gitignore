# ── Generated artifacts and runtime logs ──────────────────────────────
# These files are produced at runtime or by analysis tools.
# They must never be committed. The source code is the ground truth;
# derived artifacts belong in CI upload steps, not git.

# Log files — written by server.js, build scripts, and monkeyc
# (Already have *.log pattern above, but being explicit for generated-specific files)

# Metrics and inventory dumps — generated by analysis scripts
code_metrics.txt
project_inventory.txt

# Backup and working copies of governance documents
# CLAUDE.md is the single authoritative operating-rules file.
CLAUDE.md.good
CLAUDE.md.bak
CLAUDE.md.orig

# ── Electron Forge build outputs ────────────────────────────────────────
# out/: Forge packager output (platform-specific app bundles)
# release/: Forge make output (signed installers, DMG, AppImage, etc.)
out/
release/

# ── Code signing and distribution certificates ──────────────────────────
# Never commit private keys, signing certificates, or credential files.
# These must be supplied at CI/CD time via secrets, not stored in the repo.
*.p12
*.pfx
*.cer
*.crt
*.key
*.pem
*.der
*.keystore

# Apple-specific notarization and signing files
apple_*.json
notarization_*.txt
.apple-*

# Windows code signing
*.snk
