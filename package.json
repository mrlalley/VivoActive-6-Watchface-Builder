{
  "name": "watchface-builder",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0",
    "npm":  ">=10.0.0"
  },
  "productName": "WatchFace Builder",
  "description": "Garmin Vivoactive 6 Watch Face Visual Builder",
  "author": "WatchFace Builder",
  "homepage": "https://github.com/watchfacebuilder/watchface-builder",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "generate-constants": "node scripts/generate-constants.js",
    "generate-constants:force": "cross-env GENERATE_FORCE=1 node scripts/generate-constants.js",
    "generate-constants:ci": "node scripts/generate-constants.js --ci",
    "prestart": "npm run generate-constants",
    "start": "cross-env ELECTRON_IS_DEV=1 electron-forge start",
    "dev": "cross-env ELECTRON_IS_DEV=1 electron .",
    "preserver": "npm run generate-constants",
    "server": "node server.js",
    "prebuild": "npm run generate-constants",
    "build": "electron-forge package",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "build": {
    "appId": "com.watchfacebuilder.app",
    "productName": "WatchFace Builder",
    "directories": {
      "output": "dist-final"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "builder/**/*",
      "lib/**/*",
      "src/**/*",
      "garmin-project-template/**/*",
      "assets/**/*",
      "server.js",
      "package.json",
      "node_modules/**/*",
      "!**/*.cache.json"
    ]
  },
  "dependencies": {
    "dotenv": "~16.4.5",
    "electron-store": "8.2.0",
    "express": "~4.22.2",
    "express-rate-limit": "8.5.2",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "~7.4.0",
    "@electron-forge/maker-deb": "~7.4.0",
    "@electron-forge/maker-dmg": "~7.4.0",
    "@electron-forge/maker-rpm": "~7.4.0",
    "@electron-forge/maker-squirrel": "~7.4.0",
    "@electron-forge/maker-zip": "~7.4.0",
    "@jest/globals": "~29.7.0",
    "cross-env": "10.1.0",
    "electron": "42.3.0",
    "electron-builder": "~26.8.1",
    "electron-packager": "~17.1.2",
    "jest": "~29.7.0",
    "supertest": "7.2.2"
  },
  "allowScripts": {
    "electron@42.3.0": true
  }
}
