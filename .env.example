# Garmin SDK Configuration
# ========================
#
# Optional environment variables to configure SDK paths and directories.
# If not set, the app will auto-detect installed SDKs or use platform-aware defaults.
#
# Useful for:
# - CI/CD pipelines where SDK installation paths differ from typical user setups
# - Development when SDK is installed in a non-standard location
# - Testing with multiple SDK versions

# GARMIN_SDK_BIN
# Path to the Garmin SDK bin directory (contains monkeyc, monkeydo, simulator tools)
#
# Platform defaults (auto-detected if not set):
#   Windows:  %APPDATA%\Garmin\ConnectIQ\Sdks\<latest-version>\bin
#   macOS:    ~/Library/Application Support/Garmin/ConnectIQ/Sdks/<latest-version>/bin
#   Linux:    ~/.local/share/Garmin/ConnectIQ/Sdks/<latest-version>/bin
#             (or /opt/garmin/connectiq/sdk/bin if system-wide install)
#
# Example:
# GARMIN_SDK_BIN=/custom/path/to/sdk/bin
GARMIN_SDK_BIN=

# GARMIN_DEV_KEY
# Path to the Garmin developer signing key (RSA-4096 PKCS#8 DER format)
#
# Platform default (auto-detected if not set):
#   All platforms: ~/.garmin/developer_key.der
#
# If not found, the app will prompt you to generate a new key in Settings.
#
# Example:
# GARMIN_DEV_KEY=/path/to/developer_key.der
GARMIN_DEV_KEY=

# GARMIN_EXPORT_DIR
# Directory where exported Garmin projects are written
#
# Platform defaults (used if not set):
#   Windows:  ~/Documents/WatchFaceBuilder/exported
#   macOS:    ~/Documents/WatchFaceBuilder/exported
#   Linux:    ~/.local/share/WatchFaceBuilder/exported
#
# Example:
# GARMIN_EXPORT_DIR=/path/to/export/directory
GARMIN_EXPORT_DIR=

# GARMIN_TEMP_DIR
# Temporary directory for preview .prg files
#
# Platform defaults (used if not set):
#   Windows:  %TEMP%\CIQPreview
#   macOS:    /tmp/CIQPreview
#   Linux:    /tmp/CIQPreview
#
# Example:
# GARMIN_TEMP_DIR=/path/to/temp
GARMIN_TEMP_DIR=
