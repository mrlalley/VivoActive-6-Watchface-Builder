# WatchFace Builder Environment Configuration
# ================================================
# Copy this file to .env and fill in your actual paths.
# IMPORTANT: .env is in .gitignore and must NEVER be committed.

# ─── Required: Garmin Connect IQ SDK ───────────────────────────────────────
# Path to the Garmin Connect IQ SDK /bin directory (contains monkeyc.exe/monkeyc).
#
# The builder will auto-detect the latest SDK version in the standard install
# locations, but you can override this with an explicit path.
#
# Windows examples:
#   C:\Users\<your-username>\AppData\Roaming\Garmin\ConnectIQ\Sdks\connectiq-sdk-9.1.0-2026-03-09-6a872a80b\bin
#   C:\opt\garmin\connectiq\bin
#
# macOS examples:
#   ~/Library/Application Support/Garmin/ConnectIQ/Sdks/connectiq-sdk-9.1.0-2026-03-09-6a872a80b/bin
#
# Linux examples:
#   ~/.local/share/Garmin/ConnectIQ/Sdks/connectiq-sdk-9.1.0-2026-03-09-6a872a80b/bin
#   /opt/garmin/connectiq/sdk/bin
#
# Leave blank to auto-detect from default locations.
#
GARMIN_SDK_BIN=

# ─── Required: Developer Key (PKCS#8 DER format) ───────────────────────────
# Path to your Garmin developer key (.der file), used to sign .prg files.
#
# The builder will check the standard location: ~/.garmin/developer_key.der
# If you have generated a key elsewhere, provide the full path here.
#
# To generate a new key:
#   npm run key:generate
#   (or in the app: Settings → Generate New Key)
#
# Default location (leave blank to use):
#   ~/.garmin/developer_key.der
#
GARMIN_DEV_KEY=

# ─── Optional: Export Directory ───────────────────────────────────────────
# Directory where exported Monkey C projects will be written.
# Defaults to ~/Documents/WatchFaceBuilder/exported (Windows/macOS)
#           or ~/.local/share/WatchFaceBuilder/exported (Linux)
#
GARMIN_EXPORT_DIR=

# ─── Optional: Temporary Directory ────────────────────────────────────────
# Scratch space for build artifacts and simulator preview files.
# Defaults to system temp directory (TEMP on Windows, /tmp on Unix).
#
GARMIN_TEMP_DIR=
